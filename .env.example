# ─── GitVault Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─── Crypto (CRITICAL — root of trust) ───────────────────────────────────────
# Generate with: openssl rand -hex 32
SERVER_SECRET=your-256-bit-random-secret-here

# ─── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_APP_ID=123456
GITHUB_APP_NAME=gitvault
# Path to the downloaded .pem private key from GitHub App settings
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app-private-key.pem
# Or inline (for cloud deployments): the full PEM content as a single line with \n
GITHUB_APP_PRIVATE_KEY=

# ─── Firebase ─────────────────────────────────────────────────────────────────
# Path to downloaded Firebase Admin SDK service account JSON
FIREBASE_CREDENTIAL_PATH=/run/secrets/firebase-adminsdk.json
# Or inline as JSON string for cloud deployments
FIREBASE_CREDENTIAL_JSON=

# ─── API ──────────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
FRONTEND_URL=http://localhost:3000

# ─── SQLite ───────────────────────────────────────────────────────────────────
# Relative to the API working directory
SQLITE_PATH=gitvault.db

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_GITHUB_APP_NAME=gitvault
