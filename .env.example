# ─── GitVault Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in values. NEVER commit .env.

# ─── Crypto (raíz de confianza — generar con: openssl rand -hex 32) ──────────
SERVER_SECRET=your-256-bit-random-secret-here

# ─── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_APP_NAME=your-github-app-name
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=.secrets/github-app-private-key.pem
# O inline (para deploys cloud):
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_CREDENTIAL_PATH=.secrets/firebase-adminsdk.json
# O inline: FIREBASE_CREDENTIAL_JSON={"type":"service_account",...}

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
ASPNETCORE_URLS=http://+:5000
ASPNETCORE_ENVIRONMENT=Production
SQLITE_PATH=gitvault.db

# ─── Frontend (Next.js — copiar a web/.env.local) ─────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_GITHUB_APP_NAME=your-github-app-name

# ─── Admin Panel ──────────────────────────────────────────────────────────────
ADMIN_SECRET=your-admin-secret-here
